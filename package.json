{
  "name": "pi-parent-file-completion",
  "version": "0.1.0",
  "description": "Pi extension that adds fuzzy @../ file autocomplete outside the current working directory.",
  "type": "module",
  "license": "MIT",
  "author": "3DRX",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3DRX/pi-parent-file-completion.git"
  },
  "homepage": "https://github.com/3DRX/pi-parent-file-completion#readme",
  "bugs": {
    "url": "https://github.com/3DRX/pi-parent-file-completion/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "autocomplete",
    "file-search",
    "fuzzy-search"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "@earendil-works/pi-tui": "^0.79.9",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
