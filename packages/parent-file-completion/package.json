{
  "name": "@3drx/pi-parent-file-completion",
  "version": "0.1.0",
  "description": "Pi extension that adds fuzzy @../ file autocomplete outside the current working directory.",
  "type": "module",
  "license": "MIT",
  "author": "3DRX",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3DRX/pi-extensions-lab.git",
    "directory": "packages/parent-file-completion"
  },
  "homepage": "https://github.com/3DRX/pi-extensions-lab/tree/main/packages/parent-file-completion#readme",
  "bugs": {
    "url": "https://github.com/3DRX/pi-extensions-lab/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "autocomplete",
    "file-search",
    "fuzzy-search"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  }
